{
	"name": "ngadongeng",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply ngadongeng-db --local",
		"db:migrate:prod": "wrangler d1 migrations apply ngadongeng-db",
		"db:studio": "drizzle-kit studio",
		"cf:deploy": "pnpm build && wrangler pages deploy"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260527.1",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@iconify-json/ph": "^1.2.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"@unocss/extractor-svelte": "^66.7.0",
		"@unocss/svelte-scoped": "^66.7.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"unocss": "^66.7.0",
		"vite": "^8.0.7",
		"wrangler": "^4.95.0"
	},
	"dependencies": {
		"@auth/core": "^0.34.3",
		"@auth/drizzle-adapter": "^1.11.2",
		"@auth/sveltekit": "^1.11.2",
		"drizzle-orm": "^0.45.2"
	}
}
